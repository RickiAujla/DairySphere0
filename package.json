{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "frontend",
    "backend",
    "shared",
    "packages/*"
  ],
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:frontend": "npm run dev --workspace=@dairysphere/frontend",
    "dev:backend": "npm run start:dev --workspace=@dairysphere/backend",
    "build": "vite build",
    "build:frontend": "npm run build --workspace=@dairysphere/frontend",
    "build:backend": "npm run build --workspace=@dairysphere/backend",
    "build:shared": "npm run build --workspace=@dairysphere/shared",
    "build:core": "npm run build --workspace=@dairysphere/core",
    "build:all": "npm run build:shared && npm run build:core && npm run build:frontend && npm run build:backend",
    "docker:up": "docker-compose -f infrastructure/docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f infrastructure/docker/docker-compose.yml down",
    "docker:logs": "docker-compose -f infrastructure/docker/docker-compose.yml logs -f",
    "docker:status": "docker-compose -f infrastructure/docker/docker-compose.yml ps",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test": "npx tsx tests/runner.ts",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\" \"*.{js,json,md}\""
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@hookform/resolvers": "^5.4.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/platform-express": "^11.1.28",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "@vitejs/plugin-react": "^5.0.4",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.42.2",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-hook-form": "^7.81.0",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
